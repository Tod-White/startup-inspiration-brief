# 复制此文件为 .env 并填入你的 API keys
# cp .env.example .env

# Claude API（必填）
# 支持 Anthropic 官方或任何 OpenAI 兼容中转
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_API_BASE=https://api.anthropic.com

# Brave Search API（必填，用于抓取新闻和社区内容）
# 申请地址：https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Telegram（必填，用于推送简报）
# 获取方式：和 @userinfobot 对话获取你的 Chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Firecrawl API（可选，用于抓取 IndieHackers）
# 申请地址：https://firecrawl.dev
# 不填则跳过 IndieHackers 数据源
FIRECRAWL_API_KEY=

# 模型配置（可选，默认 claude-sonnet-4-5）
MODEL_SCORING=claude-sonnet-4-5
MODEL_REPORT=claude-sonnet-4-5
